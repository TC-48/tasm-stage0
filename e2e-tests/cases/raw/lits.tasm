set r0, 123456789
cmp! r0, 0s8G86NI
if(ne) jmp err

set r1, 0n21836758
cmp! r1, 10594448
if(ne) jmp err

set r0:t0, 0t222222
cmp! r0:t0, 728
if(ne) jmp err

set r0, 1'000'000
cmp! r0, 1_000_000
if(ne) jmp err
cmp! r0, 1000000
if(ne) jmp err

set r1, 0t_102100_012112
cmp! r1, 0n370175
if(ne) jmp err

out raz, 0sQQQQQQQQQ
